NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
# Public URL of the web app — used to build password-reset links in emails.
APP_URL=http://localhost:3000

# For the bundled `docker compose up` Postgres: port 5433, user/password audithub.
# If you run your own Postgres, use whatever host/port/creds you configured.
DATABASE_URL=postgresql://audithub:audithub@localhost:5433/audithub?schema=public

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Platform super admin — bootstrapped on every boot with its own workspace.
# This account approves new signups from the /admin control panel.
# Change the password after first login (or set a strong one here before first boot).
PLATFORM_ADMIN_EMAIL=info@digitalvetri.com
PLATFORM_ADMIN_PASSWORD=DigitalVetri@2026
PLATFORM_ADMIN_NAME=Digital Vetri Admin

# SMTP mailer — leave SMTP_HOST empty in dev to use the ConsoleMailer (logs to API stdout).
# When set, the mailer sends real email via any provider that speaks SMTP.
#
# Examples:
#   Resend:    HOST=smtp.resend.com  PORT=465  SECURE=true  USER=resend         PASS=<api key>
#   Postmark:  HOST=smtp.postmarkapp.com PORT=587 SECURE=false USER=<key> PASS=<key>
#   SES:       HOST=email-smtp.<region>.amazonaws.com PORT=587 SECURE=false USER=<smtp user> PASS=<smtp pass>
#   Gmail:     HOST=smtp.gmail.com    PORT=587 SECURE=false USER=<gmail> PASS=<app password>
#   Mailgun:   HOST=smtp.mailgun.org  PORT=587 SECURE=false USER=postmaster@<domain> PASS=<key>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AuditHub <no-reply@audithub.local>"

# Object storage — leave S3_BUCKET empty in dev to use the LocalStorage adapter
# (writes to ./uploads on disk). When set, uploads go to any S3-compatible service.
#
# Examples:
#   AWS S3:       S3_BUCKET=audithub-prod  S3_REGION=ap-south-1
#                 S3_ACCESS_KEY_ID=AKIA…   S3_SECRET_ACCESS_KEY=…
#
#   Cloudflare R2: S3_BUCKET=audithub-prod  S3_REGION=auto
#                  S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
#                  S3_ACCESS_KEY_ID=…       S3_SECRET_ACCESS_KEY=…
#
#   Backblaze B2:  S3_BUCKET=audithub-prod  S3_REGION=us-west-004
#                  S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#                  S3_ACCESS_KEY_ID=…       S3_SECRET_ACCESS_KEY=…
#
#   Wasabi:        S3_BUCKET=audithub-prod  S3_REGION=ap-southeast-1
#                  S3_ENDPOINT=https://s3.ap-southeast-1.wasabisys.com
#                  S3_ACCESS_KEY_ID=…       S3_SECRET_ACCESS_KEY=…
#
#   MinIO (dev):   S3_BUCKET=audithub       S3_REGION=us-east-1
#                  S3_ENDPOINT=http://localhost:9000
#                  S3_ACCESS_KEY_ID=minioadmin S3_SECRET_ACCESS_KEY=minioadmin
#                  S3_FORCE_PATH_STYLE=true
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
UPLOAD_ROOT=uploads

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
