// AuditHub - Prisma schema
// All tenant-scoped tables carry orgId for multi-office isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum ClientStatus {
  active
  pending
  inactive
}

enum InvoiceKind {
  invoice
  quotation
  estimate
  receipt
}

enum PaymentStatus {
  paid
  pending
  partial
  overdue
}

enum TaskStatus {
  todo
  progress
  review
  done
}

enum TaskPriority {
  low
  med
  high
}

enum ComplianceType {
  GST
  ITR
  TDS
  ROC
  LICENSE
}

// ─────────────────────────────────────────────────────────────
// Tenant + auth
// ─────────────────────────────────────────────────────────────

model Organization {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  gstin          String?
  financialYear  String?
  plan           String   @default("free")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users        User[]
  clients      Client[]
  services     Service[]
  expenses     Expense[]
  activityLogs ActivityLog[]

  @@map("organizations")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @db.Uuid
  roleId       String   @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  // Platform-level super admin (info@digitalvetri.com) — sees/approves every
  // workspace. Distinct from the per-workspace super_admin role.
  isPlatformAdmin Boolean @default(false)
  // Null until a platform admin approves the account. Lets us tell a never-yet
  // -approved "pending" user apart from an approved-then-"suspended" one.
  approvedAt   DateTime?
  // Password reset — hashed single-use token + expiry (raw token only ever emailed).
  resetTokenHash     String?
  resetTokenExpiry   DateTime?
  // Two-factor auth (TOTP). Secret is stored once setup begins; `enabled` flips
  // true only after the first code is verified. Backup codes are stored hashed.
  twoFactorEnabled   Boolean  @default(false)
  twoFactorSecret    String?
  twoFactorBackupCodes String[] @default([])
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role Role         @relation(fields: [roleId], references: [id])

  assignedClients Client[]        @relation("AssignedStaff")
  uploadedDocs    Document[]
  assignedTasks   Task[]          @relation("TaskAssignee")
  notifications   Notification[]
  activityLogs    ActivityLog[]

  @@index([orgId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Clients + companies
// ─────────────────────────────────────────────────────────────

model Client {
  id               String       @id @default(uuid()) @db.Uuid
  orgId            String       @db.Uuid
  assignedStaffId  String?      @db.Uuid
  name             String
  pan              String?
  gstin            String?
  aadhaar          String?
  mobile           String?
  email            String?
  address          String?
  notes            String?
  status           ClientStatus @default(active)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedStaff  User?        @relation("AssignedStaff", fields: [assignedStaffId], references: [id])

  companies Company[]
  documents Document[]
  invoices  Invoice[]
  tasks     Task[]
  reminders Reminder[]

  @@index([orgId])
  @@index([assignedStaffId])
  @@map("clients")
}

model Company {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @db.Uuid
  legalName    String
  businessType String?
  regNo        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────
// Documents
// ─────────────────────────────────────────────────────────────

model Document {
  id         String   @id @default(uuid()) @db.Uuid
  clientId   String   @db.Uuid
  uploadedBy String   @db.Uuid
  type       String
  name       String
  url        String
  size       Int
  mimeType   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@index([clientId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// Services catalog
// ─────────────────────────────────────────────────────────────

model Service {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @db.Uuid
  name       String
  defaultFee Decimal  @db.Decimal(12, 2)
  sacCode    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("services")
}

// ─────────────────────────────────────────────────────────────
// Billing
// ─────────────────────────────────────────────────────────────

model Invoice {
  id          String        @id @default(uuid()) @db.Uuid
  clientId    String        @db.Uuid
  number      String
  kind        InvoiceKind   @default(invoice)
  description String?
  subtotal    Decimal       @db.Decimal(12, 2)
  cgst        Decimal?      @db.Decimal(12, 2)
  sgst        Decimal?      @db.Decimal(12, 2)
  igst        Decimal?      @db.Decimal(12, 2)
  tax         Decimal       @db.Decimal(12, 2)
  total       Decimal       @db.Decimal(12, 2)
  status      PaymentStatus @default(pending)
  issuedAt    DateTime      @default(now())
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([clientId, number])
  @@index([clientId])
  @@map("invoices")
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  invoiceId String        @db.Uuid
  amount    Decimal       @db.Decimal(12, 2)
  method    String
  status    PaymentStatus @default(pending)
  dueDate   DateTime?
  paidAt    DateTime?
  reference String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model Expense {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  category  String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, date])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────
// Workflow
// ─────────────────────────────────────────────────────────────

model Task {
  id         String       @id @default(uuid()) @db.Uuid
  clientId   String?      @db.Uuid
  assigneeId String?      @db.Uuid
  title      String
  description String?
  priority   TaskPriority @default(med)
  status     TaskStatus   @default(todo)
  dueDate    DateTime?
  recurring  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([clientId])
  @@index([assigneeId])
  @@index([status])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────
// Compliance + notifications + audit
// ─────────────────────────────────────────────────────────────

model Reminder {
  id       String         @id @default(uuid()) @db.Uuid
  clientId String         @db.Uuid
  title    String?
  type     ComplianceType
  dueDate  DateTime
  offsets  Int[]          @default([30, 15, 7, 3, 1])
  channel  String         @default("email")
  active   Boolean        @default(true)
  notes    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client     Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dispatches ReminderDispatch[]

  @@index([clientId])
  @@index([dueDate])
  @@map("reminders")
}

model ReminderDispatch {
  id         String   @id @default(uuid()) @db.Uuid
  reminderId String   @db.Uuid
  offset     Int
  channel    String
  status     String   @default("sent")
  error      String?
  sentAt     DateTime @default(now())

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, offset, channel])
  @@index([reminderId])
  @@index([sentAt])
  @@map("reminder_dispatches")
}

model Notification {
  id     String    @id @default(uuid()) @db.Uuid
  userId String    @db.Uuid
  title  String
  body   String?
  link   String?
  readAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model ActivityLog {
  id       String   @id @default(uuid()) @db.Uuid
  orgId    String   @db.Uuid
  actorId  String?  @db.Uuid
  action   String
  entity   String
  entityId String?
  meta     Json?
  createdAt DateTime @default(now())

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor User?        @relation(fields: [actorId], references: [id])

  @@index([orgId, createdAt])
  @@map("activity_logs")
}
